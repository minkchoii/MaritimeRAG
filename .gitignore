
# --- 원본 규칙 PDF (저작권·용량) ---
# 로컬: data/raw_pdfs/<선급>/ 아래에 배치
# 공유: README의 OneDrive 링크 참고
# Source documents are licensed/large and must stay outside Git.
data/raw_pdfs/**
!data/raw_pdfs/**/.gitkeep

# --- 전처리·인덱스 산출물 (스크립트로 재생성 가능, 용량 큼) ---
data/processed/*
!data/processed/.gitkeep

# --- 시각화·디버그 출력 ---
outputs/

# --- 레이아웃 모델 가중치 (Hugging Face에서 다운로드) ---
models/layout/*
!models/layout/.gitkeep
models/layout/*.pt
models/layout/*.onnx
models/layout/*.pth

# --- Python / IDE ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- 환경·비밀 ---
.env
.env.*
!.env.example
*.pem
credentials.json

# --- OS / 에디터 ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*~

# --- Jupyter ---
.ipynb_checkpoints/

# --- 대용량·임시 ---
*.zip
*.7z
*.tar.gz
*.log
tmp/
temp/

# One-off local diagnostics and generated comparison reports
scripts/_tmp_*.py
data/eval/*_before.md
data/eval/*_after.md
data/eval/*_compare.md
